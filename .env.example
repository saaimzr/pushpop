# pushpop environment variables (example)
#
# Copy this file to `.env` and fill in any values you need during local development.
# `.env` is git-ignored — never commit real secrets.
# Published npm tarballs only include `dist/` and `assets/`, so `.env` never ships.

# Runtime debug logging for audio backend selection.
# PUSHPOP_DEBUG_AUDIO=1

# Skip update-notifier banner (standard update-notifier env var).
# NO_UPDATE_NOTIFIER=1

# Future slots (not yet read by the app):
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_WEBHOOK_SECRET=
# SENTRY_DSN=
