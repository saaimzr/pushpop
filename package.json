{
  "name": "pushpopper",
  "version": "0.1.7",
  "description": "Producer-style audio tags for your git commits and pushes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pushpop": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "assets"
  ],
  "keywords": [
    "git",
    "hooks",
    "audio",
    "developer-tools",
    "cli",
    "sound",
    "commit",
    "push",
    "producer-tag",
    "git-hooks"
  ],
  "author": "saaimzr",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "figlet": "^1.8.0",
    "music-metadata": "^11.12.3",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
