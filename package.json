{
  "name": "pushpopper",
  "version": "0.2.8",
  "description": "Producer-style audio tags for your git commits and pushes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pushpop": "./dist/index.js"
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{ recursive: true, force: true })\"",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "assets"
  ],
  "keywords": [
    "git",
    "hooks",
    "audio",
    "developer-tools",
    "cli",
    "sound",
    "commit",
    "push",
    "producer-tag",
    "git-hooks"
  ],
  "author": "saaimzr",
  "license": "MIT",
  "dependencies": {
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "dotenv": "^16.6.1",
    "figlet": "^1.8.0",
    "ink": "^6.8.0",
    "music-metadata": "^11.12.3",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.1",
    "react": "^19.2.5",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/update-notifier": "^6.0.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
